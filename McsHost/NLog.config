<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
	   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<!--配置修改自动加载-->
	autoReload="true"
	<!--禁用日志记录异常${basedir} -->
	throwExceptions="true"
	internalLogLevel="Off" internalLogFile="../SysLogs/nlog-internal.log">

	<!--定义日志变量-->
	<variable name="logDirectory" value="../SysLogs/${shortdate}" />
	<!--定义日志目标-->
	<targets  async="true">
		<target xsi:type="File" name="Log_info" fileName="${logDirectory}/logInfo.txt"
                       layout="${longdate} ${uppercase:${level}} ${message}" />
		<target xsi:type="File" name="Log_Debug" fileName="${logDirectory}/logDebug.txt"
                       layout="${longdate} ${uppercase:${level}} ${message}" />
		<target xsi:type="File" name="Log_Error" fileName="${logDirectory}/logErr.txt"
				   layout="${longdate} ${uppercase:${level}} ${message} ${onexception:${newline}${exception:format=tostring}}" />
	</targets>

	<!--定义日志路由-->
	<rules>
		<logger name="Microsoft.*" minlevel="Trace"  final="true" />
		<logger name="Volo.Abp.*" minlevel="Trace"  final="true" />
		<logger name="System.Net.Http.*" minlevel="Trace"  final="true" />
		<logger name ="*" level="Debug" writeTo="Log_Debug" />
		<logger name ="*" level="Info" writeTo="Log_info" />
		<logger name ="*" level="Error" writeTo="Log_Error" />
	</rules>
</nlog>