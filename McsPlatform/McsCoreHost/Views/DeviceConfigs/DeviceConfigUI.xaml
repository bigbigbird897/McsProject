<Window
    x:Class="McsCoreLib.Views.DeviceConfigUI"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    x:Name="window"
    Width="900"
    Height="600"
    prism:ViewModelLocator.AutoWireViewModel="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="av">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="1" />
            <RowDefinition Height="45" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Background="AliceBlue"
            Content="仪器配置"
            FontSize="14"
            FontWeight="Bold"
            Style="{x:Null}" />
        <DataGrid
            Grid.Row="1"
            Margin="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            ItemsSource="{Binding DeviceConfigs, UpdateSourceTrigger=PropertyChanged}"
            SelectedItem="{Binding SelectConfig, UpdateSourceTrigger=PropertyChanged}"
            Style="{x:Null}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding AddItem}" Header="添加" />
                    <Separator />
                    <MenuItem Command="{Binding DeleteItem}" Header="删除" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"
                    Header="仪器编号" />
                <DataGridTemplateColumn Width="0.3*" Header="仪器类型">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox
                                DisplayMemberPath="TypeName"
                                ItemsSource="{Binding DataContext.DeviceTypes, ElementName=window}"
                                SelectedValue="{Binding DeviceTypeID, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="TypeID"
                                Style="{x:Null}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--<DataGridTemplateColumn Header="平台编号" Width="0.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Style="{x:Null}"
                                      ItemsSource="{Binding  DataContext.LineConfigs,ElementName=window}"
                                      SelectedValue="{Binding LineID, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="LineID"
                                      DisplayMemberPath="LineID" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                <DataGridTemplateColumn Width="0.2*" Header="操作位编号">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox
                                DisplayMemberPath="StationName"
                                ItemsSource="{Binding DataContext.Stations, ElementName=window}"
                                SelectedValue="{Binding StationID, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="StationID"
                                Style="{x:Null}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="详细参数">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Command="{Binding DataContext.OpenParaConfigUI, ElementName=window}"
                                Content="参数明细..."
                                Style="{x:Null}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border
            Grid.Row="2"
            BorderBrush="Gray"
            BorderThickness="1" />
        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="5"
                Command="{Binding DataSave}"
                Content="保   存"
                FontWeight="Bold" />
            <Button
                Width="100"
                Margin="5"
                Command="{Binding SaveCancel}"
                CommandParameter="{Binding ElementName=window}"
                Content="退   出"
                FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>