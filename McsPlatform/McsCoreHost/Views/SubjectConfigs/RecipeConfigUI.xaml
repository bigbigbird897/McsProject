<Window
    x:Class="McsCoreLib.Views.SubjectConfigs.RecipeConfigUI"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    x:Name="win"
    Width="1200"
    Height="700"
    prism:ViewModelLocator.AutoWireViewModel="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="av">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="1" />
            <RowDefinition Height="45" />
        </Grid.RowDefinitions>
        <Label
            Grid.ColumnSpan="2"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Background="AliceBlue"
            Content="流程配置"
            FontSize="16"
            FontWeight="Bold"
            Style="{x:Null}" />
        <DataGrid
            Grid.Row="1"
            Grid.Column="0"
            Margin="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            ItemsSource="{Binding RecipeConfigs, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            SelectedItem="{Binding SelectRecipe, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            Style="{x:Null}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding AddRecipeItem}" Header="添加" />
                    <Separator />
                    <MenuItem Command="{Binding RemoveRecipeItem}" Header="删除" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <!--<DataGridTextColumn Header="流程编号" Width="*" Binding="{Binding RecipeID,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />-->
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding RecipeName, UpdateSourceTrigger=PropertyChanged}"
                    Header="流程名称" />
                <DataGridCheckBoxColumn Binding="{Binding IsDisable, UpdateSourceTrigger=PropertyChanged}" Header="禁用" />
            </DataGrid.Columns>
        </DataGrid>
        <DataGrid
            Grid.Row="1"
            Grid.Column="1"
            Margin="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            ItemsSource="{Binding SelectRecipe.Steps, UpdateSourceTrigger=PropertyChanged}"
            SelectedItem="{Binding SelectStep, UpdateSourceTrigger=PropertyChanged}"
            Style="{x:Null}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding AddStepItem}" Header="添加" />
                    <Separator />
                    <MenuItem Command="{Binding RemoveStepItem}" Header="删除" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding StepID, UpdateSourceTrigger=PropertyChanged}" Header="步序号" />
                <DataGridTemplateColumn Width="0.5*" Header="步序类型">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox
                                DisplayMemberPath="StepTypeName"
                                ItemsSource="{Binding DataContext.StepTypes, ElementName=win}"
                                SelectedValue="{Binding StepTypeID, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="StepTypeID"
                                Style="{x:Null}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding StepName, UpdateSourceTrigger=PropertyChanged}"
                    Header="步序名称" />
                <DataGridTemplateColumn Header="参数明细">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Margin="1"
                                Command="{Binding DataContext.SetStepPara, ElementName=win}"
                                Content="明细..."
                                Style="{x:Null}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Binding="{Binding IsDisable, UpdateSourceTrigger=PropertyChanged}" Header="禁用" />
            </DataGrid.Columns>
        </DataGrid>
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="2,0,2,0"
            BorderBrush="Gray"
            BorderThickness="1" />
        <StackPanel
            Grid.Row="3"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="5"
                Command="{Binding SaveData}"
                CommandParameter="{Binding ElementName=win}"
                Content="保 存"
                FontWeight="Bold" />
            <Button
                Width="100"
                Margin="5"
                Command="{Binding Quit}"
                CommandParameter="{Binding ElementName=win}"
                Content="退 出"
                FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>